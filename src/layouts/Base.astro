---
interface Props {
	title?: string;
}

const { title = 'coder@portfolio' } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta
			name="description"
			content="Terminal-style portfolio for a senior software engineer focused on Angular, TypeScript, Node.js, and Linux."
		/>
		<title>{title}</title>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
	</head>
	<body>
		<slot />
	</body>
</html>

<style lang="less" is:global>
	@import '../styles/global.less';
</style>
