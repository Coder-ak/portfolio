---
import { profile } from '../../data/portfolio';
import styles from './terminal.module.less';
---

<div class={styles.terminalBody}>
	<div
		class={styles.terminalOutput}
		id="terminal-output"
		role="log"
		aria-live="polite"
		aria-label="Terminal output"
	></div>

	<label class={styles.terminalInputRow} for="terminal-input">
		<span class={styles.terminalPromptLabel} aria-hidden="true">{`${profile.handle}@${profile.host}:~$`}</span>
		<input
			id="terminal-input"
			class={styles.terminalInput}
			type="text"
			autocomplete="off"
			autocorrect="off"
			autocapitalize="off"
			spellcheck="false"
			placeholder="type help"
			aria-label="Terminal command input"
		/>
	</label>
</div>

<script>
	import { initTerminal } from './terminal.client';

	initTerminal();
</script>
