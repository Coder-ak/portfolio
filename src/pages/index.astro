---
import Base from '../layouts/Base.astro';
import Terminal from '../components/Terminal/Terminal.astro';
---

<Base title="coder@portfolio">
	<main class="page-shell">
		<Terminal />
	</main>
</Base>

<style lang="less">
	.page-shell {
		display: grid;
		min-height: 100dvh;
		padding: 2rem 1rem;
		place-items: center;

		@media (max-width: 720px) {
			padding: 0;
			place-items: stretch;
		}
	}
</style>
